rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Public Access for Test & Baseline
    match /test/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // --- Primitives & Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "andrewsantoss658@gmail.com"
      );
    }
    
    // Identity verification for public/anonymous users
    function isPublicUser(userId) {
      return userId == "anonymous";
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Specific Validations ---

    function isValidUser(data) {
      return data.email is string 
          && data.displayName is string 
          && data.uid is string;
    }

    function isValidVerification(data) {
      return data.keys().hasAll(['type', 'content', 'userId', 'createdAt'])
          && data.type in ['text', 'image', 'video', 'link']
          && data.content is string
          && data.userId is string
          && (data.createdAt == request.time || data.createdAt is timestamp);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /verifications/{verifyId} {
      allow read: if true;
      allow create: if isValidVerification(incoming()) && (isPublicUser(incoming().userId) || isOwner(incoming().userId));
      allow update, delete: if isAdmin();
    }

    match /viral_trends/{trendId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /known_fakes/{fakeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata_reports/{reportId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
    }

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
