rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Safety Net
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Storage rules can't directly check Firestore data easily without external functions
      // or custom claims. If custom claims aren't used, we rely on paths or metadata.
      // Usually, admin-only paths are the safest.
      return isSignedIn() && request.auth.token.admin == true;
    }

    // User Files (e.g. analysis images, profile pics)
    match /users/{userId}/{allPaths=**} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId 
                   && request.resource.size < 5 * 1024 * 1024 // Limit 5MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Public Assets (Read-only for users, Write for admins)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
