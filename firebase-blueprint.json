{
  "entities": {
    "User": {
      "title": "Usuário do Sentinel",
      "description": "Dados do usuário e saldo de créditos",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isPremium": { "type": "boolean" },
        "balance": { "type": "number" },
        "reputationScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "loginType": { "type": "string" },
        "fullName": { "type": "string" },
        "birthDate": { "type": "string" },
        "transactions": { "type": "array" }
      },
      "required": ["uid", "email", "isAdmin", "balance"]
    },
    "Verification": {
      "title": "Análise de Vericidade",
      "description": "Registro de uma checagem realizada pelo sistema",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video", "link"] },
        "content": { "type": "string" },
        "hash": { "type": "string" },
        "result": { "type": "string" },
        "explanation": { "type": "string" },
        "technicalDetails": { "type": "string" },
        "reliabilityScore": { "type": "number" },
        "riskLevel": { "type": "string", "enum": ["Baixo", "Médio", "Alto"] },
        "sourceRating": { "type": "string", "enum": ["Confiável", "Duvidosa", "Desconhecida"] },
        "sources": { "type": "array" },
        "references": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "feedbackVotes": { "type": "object" }
      },
      "required": ["userId", "type", "content", "createdAt"]
    },
    "ViralTrend": {
      "title": "Tendência Viral",
      "description": "Notícias que estão viralizando e precisam de atenção",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "result": { "type": "string" },
        "viralityScore": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "viralityScore"]
    }
  },
  "firestore": {
    "/test/connection": {
      "schema": "object",
      "description": "Documento para teste de conectividade"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Perfis de usuários"
    },
    "/verifications/{verifyId}": {
      "schema": "Verification",
      "description": "Histórico de checagens"
    },
    "/viral_trends/{trendId}": {
      "schema": "ViralTrend",
      "description": "Monitoramento de tendências"
    },
    "/known_fakes/{fakeId}": {
      "schema": "Verification",
      "description": "Base de dados interna de fakes conhecidos"
    }
  }
}
